# Vercel frontend settings
# Use your hosted Supabase project values if you also use Supabase services.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Keep this unset or true for Vercel Hobby so hosted AI tabs use /api/functions/*.
# Set to false only if you intentionally want hosted frontend calls to go to Supabase Edge Functions.
VITE_USE_VERCEL_AI_API=true

# Server-side provider secrets for Vercel Environment Variables.
# Add only the providers you actually use.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter metadata.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Test Case Generator
