# No function secrets are required for the default local setup.
# Provider API keys are entered in the app UI and stored in browser local storage.
#
# Optional backend-owned provider secrets:
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GEMINI_API_KEY=your_gemini_key
# GROQ_API_KEY=your_groq_key
# OPENROUTER_API_KEY=your_openrouter_key
#
# Optional OpenRouter metadata for hosted deployments:
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_APP_TITLE=Test Case Generator Local
